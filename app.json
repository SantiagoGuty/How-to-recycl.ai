{
  "expo": {
    "name": "Recycl.ai",
    "slug": "recycl-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Recyclai_logo_v1.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "recycl.ai uses your location to find recycling rules for your area."
      }
    },
    "android": {
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/Recyclai_logo_small.png",
        "backgroundColor": "#ffffff"
      },
      "backgroundColor": "#0A0B1F",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sgutierr.howtorecyclai"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "recycl.ai uses your camera to identify materials and scan barcodes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "recycl.ai accesses your photo library so you can upload items to identify."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "b4829da0-1f40-4bd2-ab6c-84335197d8f2"
      }
    }
  }
}
